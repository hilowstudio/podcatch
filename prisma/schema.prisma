// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client"
  output          = "./generated_new"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

// Episode processing status
enum EpisodeStatus {
  DISCOVERED // Episode found in RSS feed
  PROCESSING // Transcription and AI analysis in progress
  COMPLETED // All processing complete
  FAILED // Processing failed
}

// NextAuth User model with API keys
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?

  // User's personal API keys (optional - falls back to system keys)
  // AI & Integrations
  autoSyncToClaude Boolean? @default(false)
  claudeApiKey     String?
  claudeProjectId  String?
  geminiApiKey     String?
  deepgramApiKey   String?
  openaiApiKey     String? // For future OpenAI support

  // Phase 2 Integrations
  webhookUrl              String? // Generic Webhook
  readwiseApiKey          String? // Readwise Reader
  notionAccessToken       String? // Notion OAuth
  notionPageId            String? // Notion Target Page
  googleDriveRefreshToken String? // Google Drive OAuth
  tanaApiToken            String? // Tana Input API
  logseqGraphName         String? // Logseq Graph Name for deep links
  slackWebhookUrl         String? // Slack Incoming Webhook
  obsidianVaultName       String? // Obsidian Vault Name

  // Stripe Pro Subscription
  stripeCustomerId       String?   @unique @map(name: "stripe_customer_id")
  stripeSubscriptionId   String?   @unique @map(name: "stripe_subscription_id")
  stripePriceId          String?   @map(name: "stripe_price_id")
  stripeCurrentPeriodEnd DateTime? @map(name: "stripe_current_period_end")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts Account[]
  sessions Session[]

  openaiKey           String?
  openaiAssistantId   String?
  openaiVectorStoreId String?

  // User's API keys and Subscription relations
  subscriptions Subscription[]
  notifications Notification[]
  snips         Snip[]
  collections   Collection[]
  customPrompts CustomPrompt[]
  brandVoice      String?        @db.Text
  digestFrequency String         @default("NONE") // NONE, DAILY, WEEKLY
  lastDigestAt    DateTime?
  timezone           String?  // IANA timezone e.g. "America/New_York"
  digestDeliveryTime String?  // "HH:mm" format, default "08:00"
  quietHoursStart    String?  // "HH:mm" e.g. "22:00"
  quietHoursEnd      String?  // "HH:mm" e.g. "07:00"
  deactivatedAt      DateTime?
  usageLogs       UsageLog[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([sessionToken])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// User-Feed Subscription (Many-to-Many via Join Table)
model Subscription {
  id          String   @id @default(cuid())
  userId      String
  feedId      String
  autoProcess Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  feed Feed @relation(fields: [feedId], references: [id], onDelete: Cascade)

  @@unique([userId, feedId]) // Prevent duplicate subscriptions
  @@index([userId])
  @@index([feedId])
}

// Feed Type Enum
enum FeedType {
  RSS
  YOUTUBE
}

// RSS Feed model
model Feed {
  id            String    @id @default(cuid())
  url           String    @unique
  title         String?
  image         String?
  type          FeedType  @default(RSS)
  channelId     String? // For YouTube Channel ID
  lastCheckedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relation removed to fix validation. userId scalar retained.
  // user     User?      @relation(fields: [userId], references: [id])

  episodes      Episode[]
  subscriptions Subscription[]

  @@index([lastCheckedAt])
}

// Podcast Episode model
model Episode {
  id            String        @id @default(cuid())
  title         String
  description   String?       @db.Text
  audioUrl      String
  videoUrl      String? // For YouTube Watch URL
  youtubeId     String? // For YouTube Video ID
  transcriptUrl String? // Source URL for existing transcript (e.g. from RSS)
  publishedAt   DateTime
  status        EpisodeStatus @default(DISCOVERED)
  feedId        String
  guid          String        @unique // RSS guid for deduplication
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  feed        Feed               @relation(fields: [feedId], references: [id], onDelete: Cascade)
  insight     Insight?
  snips       Snip[]
  embeddings  EpisodeEmbedding[]
  entities    Entity[]
  collections Collection[]

  @@index([feedId])
  @@index([status])
  @@index([publishedAt])
}

// Collections (Phase 3)
model Collection {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  episodes Episode[] // Many-to-many
  insights CollectionInsight[]

  @@index([userId])
}

model CollectionInsight {
  id           String   @id @default(cuid())
  collectionId String
  synthesis    String   @db.Text // The meta-summary
  createdAt    DateTime @default(now())

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@index([collectionId])
}

// Custom Prompts (Phase 3)
model CustomPrompt {
  id        String   @id @default(cuid())
  userId    String
  title     String
  prompt    String   @db.Text // Template with {{transcript}} placeholder
  isPublic  Boolean  @default(false)
  useCount  Int      @default(0)
  category  String?  // business, education, research, content
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isPublic, useCount])
}

// Entities (Knowledge Graph)
model Entity {
  id          String   @id @default(cuid())
  name        String   @unique
  type        String // PERSON, BOOK, CONCEPT
  description String?  @db.Text
  image       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  episodes Episode[]
}

// AI-generated insights
model Insight {
  id            String   @id @default(cuid())
  episodeId     String   @unique
  transcript    String   @db.Text
  summary       String   @db.Text
  keyTakeaways  Json // Array of 5 bullet points
  links         Json // Array of URLs mentioned
  socialContent Json? // { tweet, linkedin, blogTitle }
  chapters       Json? // [{ title, start, end }]
  wordTimestamps Json? // [{ word, start, end, speaker }] for animated transcript
  geminiFileUri  String? // URI of the file uploaded to Gemini for RAG
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  episode Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@index([episodeId])
}

// User Notifications
model Notification {
  id          String    @id @default(cuid())
  userId      String
  title       String
  message     String
  read        Boolean   @default(false)
  link        String? // Optional link to navigate to (e.g., /episodes/123)
  type        String    @default("INFO") // INFO, SUCCESS, ERROR
  queuedUntil DateTime? // If set, notification is held until this time (quiet hours)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
  @@index([createdAt])
}

// User Snips (Highlights)
model Snip {
  id        String   @id @default(cuid())
  userId    String
  episodeId String
  startTime Int // Seconds
  endTime   Int // Seconds
  content   String?  @db.Text
  note      String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  episode Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([episodeId])
}

// Vector Embeddings for RAG
model EpisodeEmbedding {
  id        String                     @id @default(cuid())
  episodeId String
  content   String                     @db.Text // The chunk text
  vector    Unsupported("vector(768)") // Gemini text-embedding-004 is 768 dim
  createdAt DateTime                   @default(now())

  episode Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@index([episodeId])
}

// Usage Tracking for Billing Limits
model UsageLog {
  id        String   @id @default(cuid())
  userId    String
  action    String // e.g., "PROCESS_EPISODE", "CHAT_MESSAGE"
  targetId  String? // e.g., episodeId
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// Rate Limiting
model RateLimit {
  id        String   @id @default(cuid())
  ip        String   @unique
  count     Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([expiresAt])
}
